{
  "expo": {
    "name": "xclnc-pos",
    "slug": "xclnc-pos",
    "version": "1.0.0",
    "orientation": "default",
    "icon": "./assets/app-icon.png",
    "scheme": "xclncpos",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "com.xclnc.pos",
      "icon": "./assets/app-icon.png"
    },
    "android": {
      "package": "com.xclnc.pos",
      "adaptiveIcon": {
        "backgroundColor": "#f8fafc",
        "foregroundImage": "./assets/adaptive-foreground.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon-square.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "headers": {
            "Cross-Origin-Embedder-Policy": "credentialless",
            "Cross-Origin-Opener-Policy": "same-origin"
          }
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#f8fafc",
          "image": "./assets/splash.png",
          "imageWidth": 160
        }
      ],
      [
        "expo-font",
        {
          "fonts": [
            "./assets/fonts/Sarabun-Regular.ttf",
            "./assets/fonts/Sarabun-Medium.ttf",
            "./assets/fonts/Sarabun-SemiBold.ttf",
            "./assets/fonts/Sarabun-Bold.ttf",
            "./assets/fonts/Sarabun-ExtraBold.ttf"
          ],
          "android": {
            "fonts": [
              {
                "fontFamily": "Sarabun",
                "fontDefinitions": [
                  {
                    "path": "./assets/fonts/Sarabun-Regular.ttf",
                    "weight": 400
                  },
                  {
                    "path": "./assets/fonts/Sarabun-Medium.ttf",
                    "weight": 500
                  },
                  {
                    "path": "./assets/fonts/Sarabun-SemiBold.ttf",
                    "weight": 600
                  },
                  {
                    "path": "./assets/fonts/Sarabun-Bold.ttf",
                    "weight": 700
                  },
                  {
                    "path": "./assets/fonts/Sarabun-ExtraBold.ttf",
                    "weight": 800
                  }
                ]
              }
            ]
          }
        }
      ],
      "expo-sqlite",
      "expo-sharing"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {
        "headers": {
          "Cross-Origin-Embedder-Policy": "credentialless",
          "Cross-Origin-Opener-Policy": "same-origin"
        }
      },
      "eas": {
        "projectId": "092e3024-fe9b-4fba-a3a5-81a975e35cac"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/092e3024-fe9b-4fba-a3a5-81a975e35cac"
    }
  }
}
